# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Free API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── Google Cloud (BigQuery) ───────────────────────────────────────────────────
GCP_PROJECT_ID=energy-genai-assistant
BIGQUERY_DATASET=rte_energy
# Path to a service-account JSON key (only needed to query BigQuery locally).
# In Cloud Run this is provided automatically by the runtime service account.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# ── LangSmith (observability, optional) ───────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=energy-genai-assistant

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
